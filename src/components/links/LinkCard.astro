---
import { Icon } from 'astro-icon/components';
import type { LinkStyle } from '../../data/links';

interface Props {
  title: string;
  link: string;
  desc: string;
  img?: string;
  style?: LinkStyle;
}

const { title, link, desc, img, style = 'default' } = Astro.props;
const isPremium = style === 'premium';
const initial = title.charAt(0);
const hasImg = img && img.trim() !== '';
---

<div
  class="flex flex-nowrap items-stretch h-24 gap-5 rounded-[var(--radius-large)]"
  class:list={[{ 'font-serif': isPremium }]}
>
  <div
    class="w-24 h-24 flex-shrink-0 rounded-lg overflow-hidden bg-zinc-200 dark:bg-zinc-800 relative"
  >
    <!-- 骨架屏占位：加载中脉冲，失败/无图时显示静态首字母 -->
    <div
      class="absolute inset-0 flex items-center justify-center text-zinc-300 dark:text-zinc-600 text-3xl font-bold animate-pulse select-none"
      class:list={[{ 'opacity-0': !hasImg }]}
    >
      {hasImg ? initial : <Icon name="material-symbols:link" class="text-3xl" />}
    </div>

    {hasImg && (
      <img
        src={img}
        alt="站点头像"
        class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300"
        loading="lazy"
        onload="this.style.opacity='1'; this.previousElementSibling.style.display='none'"
        onerror="this.style.display='none'; this.previousElementSibling.classList.remove('animate-pulse')"
      />
    )}
  </div>
  <div class="grow w-full flex flex-col justify-center gap-1">
    <div
      class="font-bold transition"
      class:list={[
        isPremium ? 'text-yellow-600' : 'text-neutral-700 dark:text-neutral-200',
      ]}
    >
      {title}
    </div>
    <div class="text-50 text-sm font-medium mb-1">{desc}</div>
  </div>
  <a
    href={link}
    target="_blank"
    rel="noopener noreferrer"
    class="flex btn-regular w-16 rounded-lg bg-[var(--enter-btn-bg)] hover:bg-[var(--enter-btn-bg-hover)] active:bg-[var(--enter-btn-bg-active)] active:scale-95"
  >
    <Icon
      name="material-symbols:chevron-right-rounded"
      class="transition text-[var(--primary)] text-3xl mx-auto"
    />
  </a>
</div>
